+                                        <div class="entry-meta">
+                                            <?php
+                                            insynia_posted_on();
+                                            insynia_posted_by();
+                                            ?>
+                                        </div><!-- .entry-meta -->
+                                    </header><!-- .entry-header -->
+
+                                    <div class="entry-content">
+                                        <?php the_excerpt(); ?>
