+.comment-body {
+    background-color: #f9fafb;
+    padding: 1.5rem;
+    border-radius: 8px;
+    margin-bottom: 1rem;
+}
+
+.comment-author img {
+    border-radius: 50%;
+    margin-right: 1rem;
+}
+
+.comment-content {
