+
+                            </article><!-- #post-<?php the_ID(); ?> -->
+
+                        <?php endwhile; ?>
+
+                    </div><!-- .posts-grid -->
+
+                    <!-- Pagination -->
+                    <div class="pagination-wrapper">
+                        <?php
+                        the_posts_pagination( array(
+                            'mid_size'  => 2,
+                            'prev_text' => __( '&larr; Previous', 'insynia' ),
+                            'next_text' => __( 'Next &rarr;', 'insynia' ),
